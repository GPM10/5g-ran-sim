FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY ai_5g_load_balancing/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY ai_5g_load_balancing /app

ENTRYPOINT ["python", "xapp_agent.py"]
CMD ["--api-base", "http://ric-api:8000", "--interval", "1.0", "--steps", "0"]
