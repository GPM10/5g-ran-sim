FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY ai_5g_load_balancing/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY ai_5g_load_balancing /app

EXPOSE 8000

CMD ["uvicorn", "ric_api:app", "--host", "0.0.0.0", "--port", "8000"]
